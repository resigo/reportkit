{
  "version": 1,
  "id": "demo_sales",
  "title": "Demo Sales Dashboard",
  "description": "Product sales overview across regions",
  "theme": "default",
  "reviewMode": true,
  "filters": [
    {
      "id": "region",
      "label": "Region",
      "uiType": "dropdown",
      "model": "demo_sales",
      "column": "region",
      "default": "__all__"
    },
    {
      "id": "date_range",
      "label": "Date",
      "uiType": "daterange",
      "default": "__all__"
    }
  ],
  "data": [
    {
      "id": "total_revenue",
      "model": "demo_sales",
      "metrics": [
        "total_revenue"
      ],
      "filterColumns": {
        "region": "region",
        "date_range": "date"
      }
    },
    {
      "id": "total_units",
      "model": "demo_sales",
      "metrics": [
        "total_units"
      ],
      "filterColumns": {
        "region": "region",
        "date_range": "date"
      }
    },
    {
      "id": "avg_price",
      "model": "demo_sales",
      "metrics": [
        "avg_price"
      ],
      "filterColumns": {
        "region": "region",
        "date_range": "date"
      }
    },
    {
      "id": "revenue_by_month",
      "model": "demo_sales",
      "sql": "SELECT substr(date, 1, 7) as month, SUM(revenue) as revenue FROM {{table}} WHERE true [[AND region = @region]] [[AND date >= @date_range.start AND date <= @date_range.end]] [[AND product = @panel_product]] GROUP BY month ORDER BY month"
    },
    {
      "id": "revenue_trend_by_region",
      "model": "demo_sales",
      "sql": "SELECT substr(date, 1, 7) as month, region, SUM(revenue) as revenue FROM {{table}} WHERE true [[AND region = @region]] [[AND date >= @date_range.start AND date <= @date_range.end]] GROUP BY month, region ORDER BY month"
    },
    {
      "id": "revenue_by_product",
      "model": "demo_sales",
      "metrics": [
        "total_revenue"
      ],
      "dimensions": [
        "product"
      ],
      "filterColumns": {
        "region": "region",
        "date_range": "date"
      }
    },
    {
      "id": "share_by_region",
      "model": "demo_sales",
      "sql": "SELECT region, SUM(revenue) as revenue FROM {{table}} WHERE true [[AND region = @region]] [[AND date >= @date_range.start AND date <= @date_range.end]] [[AND product = @panel_product_pie]] GROUP BY region ORDER BY revenue DESC"
    },
    {
      "id": "revenue_by_product_bar",
      "model": "demo_sales",
      "sql": "SELECT product, SUM(revenue) as total_revenue FROM {{table}} WHERE true [[AND region = @region]] [[AND date >= @date_range.start AND date <= @date_range.end]] [[AND product = @panel_product_bar]] GROUP BY product ORDER BY total_revenue DESC"
    },
    {
      "id": "units_by_month",
      "model": "demo_sales",
      "sql": "SELECT substr(date, 1, 7) as month, SUM(units) as units FROM {{table}} WHERE true [[AND region = @region]] [[AND date >= @date_range.start AND date <= @date_range.end]] GROUP BY month ORDER BY month"
    },
    {
      "id": "product_scatter",
      "model": "demo_sales",
      "sql": "SELECT product, SUM(units) as units, SUM(revenue) as revenue FROM {{table}} WHERE true [[AND region = @region]] [[AND date >= @date_range.start AND date <= @date_range.end]] GROUP BY product"
    },
    {
      "id": "monthly_by_product",
      "model": "demo_sales",
      "sql": "SELECT substr(date, 1, 7) as month, product, SUM(revenue) as revenue FROM {{table}} WHERE true [[AND region = @panel_region]] [[AND date >= @date_range.start AND date <= @date_range.end]] GROUP BY month, product ORDER BY month"
    },
    {
      "id": "detail",
      "model": "demo_sales",
      "sql": "SELECT date as Date, region as Region, product as Product, units as Units, revenue as Revenue FROM {{table}} WHERE true [[AND region = @region]] [[AND date >= @date_range.start AND date <= @date_range.end]] ORDER BY date DESC"
    }
  ],
  "pages": [
    {
      "id": "overview",
      "title": "Overview",
      "layout": [
        {
          "id": "header_title",
          "type": "Title",
          "title": "Sales Performance Overview",
          "level": 1,
          "row": 1,
          "col": 1,
          "span": 24,
          "height": 2,
          "paddingRight": 10,
          "paddingTop": 12
        },
        {
          "id": "header_text",
          "type": "Text",
          "content": "Track revenue, units sold, and product performance across all regions. Use the Region filter above to drill into specific markets.",
          "row": 3,
          "col": 19,
          "span": 6,
          "height": 4,
          "paddingRight": 6
        },
        {
          "id": "kpi_revenue",
          "type": "KPICard",
          "title": "Total Revenue",
          "data": "total_revenue",
          "value": "total_revenue",
          "unit": "$",
          "row": 3,
          "col": 1,
          "span": 6,
          "height": 4
        },
        {
          "id": "kpi_units",
          "type": "KPICard",
          "title": "Total Units",
          "data": "total_units",
          "value": "total_units",
          "row": 3,
          "col": 7,
          "span": 6,
          "height": 4
        },
        {
          "id": "kpi_avg",
          "type": "KPICard",
          "title": "Avg Price",
          "data": "avg_price",
          "value": "avg_price",
          "unit": "$",
          "row": 3,
          "col": 13,
          "span": 6,
          "height": 4
        },
        {
          "id": "revenue_area",
          "type": "AreaChart",
          "title": "Monthly Revenue",
          "data": "revenue_by_month",
          "x": "month",
          "y": "revenue",
          "row": 7,
          "col": 1,
          "span": 14,
          "height": 10,
          "chartStyle": {
            "fillOpacity": 0.12
          },
          "colors": [
            "#0066FF"
          ],
          "filters": [
            {
              "id": "panel_product",
              "label": "Product",
              "uiType": "dropdown",
              "model": "demo_sales",
              "column": "product",
              "default": "__all__"
            }
          ]
        },
        {
          "id": "region_pie",
          "type": "PieChart",
          "title": "Revenue by Region",
          "data": "share_by_region",
          "label": "region",
          "value": "revenue",
          "row": 7,
          "col": 15,
          "span": 10,
          "height": 10,
          "colors": [
            "#0066FF"
          ],
          "filters": [
            {
              "id": "panel_product_pie",
              "label": "Product",
              "uiType": "dropdown",
              "model": "demo_sales",
              "column": "product",
              "default": "__all__"
            }
          ]
        },
        {
          "id": "product_bar",
          "type": "BarChart",
          "title": "Revenue by Product",
          "data": "revenue_by_product_bar",
          "x": "product",
          "y": "total_revenue",
          "row": 17,
          "col": 1,
          "span": 12,
          "height": 10,
          "chartStyle": {
            "showValues": true,
            "labelAngle": 0
          },
          "filters": [
            {
              "id": "panel_product_bar",
              "label": "Product",
              "uiType": "dropdown",
              "model": "demo_sales",
              "column": "product",
              "default": "__all__"
            }
          ]
        },
        {
          "id": "region_line",
          "type": "LineChart",
          "title": "Revenue Trend by Region",
          "data": "revenue_trend_by_region",
          "x": "month",
          "y": "revenue",
          "colorBy": "region",
          "row": 17,
          "col": 13,
          "span": 12,
          "height": 10
        }
      ]
    },
    {
      "id": "products",
      "title": "Product Analysis",
      "layout": [
        {
          "id": "product_rank",
          "type": "HorizontalBarChart",
          "title": "Product Ranking",
          "data": "revenue_by_product",
          "x": "total_revenue",
          "y": "product",
          "row": 4,
          "col": 1,
          "span": 10,
          "height": 10,
          "chartStyle": {
            "showValues": true
          }
        },
        {
          "id": "product_scatter",
          "type": "ScatterChart",
          "title": "Units vs Revenue",
          "data": "product_scatter",
          "x": "units",
          "y": "revenue",
          "colorBy": "product",
          "row": 4,
          "col": 11,
          "span": 14,
          "height": 10,
          "chartStyle": {
            "pointRadius": 6
          }
        },
        {
          "id": "units_area",
          "type": "AreaChart",
          "title": "Monthly Units Sold",
          "data": "units_by_month",
          "x": "month",
          "y": "units",
          "row": 14,
          "col": 1,
          "span": 12,
          "height": 10,
          "chartStyle": {
            "fillOpacity": 0.15
          }
        },
        {
          "id": "stacked_product",
          "type": "BarChart",
          "title": "Revenue by Product (Monthly)",
          "data": "monthly_by_product",
          "x": "month",
          "y": "revenue",
          "stack": "product",
          "row": 14,
          "col": 13,
          "span": 12,
          "height": 10,
          "filters": [
            {
              "id": "panel_region",
              "label": "Region",
              "uiType": "dropdown",
              "model": "demo_sales",
              "column": "region",
              "default": "__all__"
            }
          ]
        },
        {
          "id": "detail_table",
          "type": "DataTable",
          "title": "Sales Detail",
          "data": "detail",
          "row": 24,
          "col": 1,
          "span": 24,
          "height": 11
        },
        {
          "id": "panel_kv23mr",
          "row": 1,
          "col": 1,
          "span": 12,
          "height": 3,
          "type": "Title",
          "title": "Products Analysis",
          "level": 1
        }
      ]
    }
  ]
}